# Sagor Photography — Apache config

# PHP version — uncomment ONE line that matches your cPanel PHP handler
# (check cPanel → MultiPHP Manager for the correct handler name)
#AddHandler application/x-httpd-php74 .php
#AddHandler application/x-httpd-php80 .php
#AddHandler application/x-httpd-php81 .php
#AddHandler application/x-httpd-php82 .php
#AddHandler application/x-httpd-php83 .php

# Deny directory listing
Options -Indexes

# Protect bookings log
<FilesMatch "\.log$">
    <IfVersion >= 2.4>
        Require all denied
    </IfVersion>
    <IfVersion < 2.4>
        Order allow,deny
        Deny from all
    </IfVersion>
</FilesMatch>

# Protect includes directory
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct access to includes/
    RewriteRule ^includes/.*$ - [F,L]

    # Block direct access to bookings/
    RewriteRule ^bookings/.*$ - [F,L]

    # Block direct access to db/
    RewriteRule ^db/.*$ - [F,L]
</IfModule>

# Charset
AddDefaultCharset UTF-8
