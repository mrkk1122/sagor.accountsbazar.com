# Sagor Photography — Apache / LiteSpeed config

# Deny directory listing
Options -Indexes

# Protect log files
<FilesMatch "\.log$">
    Require all denied
</FilesMatch>

# Protect includes directory
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Allow only the AI API endpoint from includes/
    RewriteRule ^includes/ai_generate_api\.php$ - [L]

    # Block direct access to includes/
    RewriteRule ^includes/.*$ - [F,L]

    # Block direct access to bookings/
    RewriteRule ^bookings/.*$ - [F,L]

    # Block direct access to db/
    RewriteRule ^db/.*$ - [F,L]
</IfModule>

# AI key via Apache env (replace with your real key on server)
<IfModule mod_env.c>
    SetEnv OPENROUTER_API_KEY "YOUR_OPENROUTER_API_KEY"
</IfModule>

# Charset
AddDefaultCharset UTF-8

# PHP upload limits (XAMPP/mod_php)
php_value upload_max_filesize 92M
php_value post_max_size 100M
php_value max_execution_time 120
php_value max_input_time 120
php_value memory_limit 256M
